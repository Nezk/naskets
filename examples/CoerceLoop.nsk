module Main where

Eq :: * -> * -> *
Eq = \a b. forall p :: * -> *. p a -> p b

coerce : forall a b :: *. Eq a b -> a -> b
coerce = /\a b. \eq. eq [\alpha :: *. alpha]

loop : forall a :: *. {} -> a
loop = /\a. fix (\f. \u. f u) -- f : {} -> a, u : {}

main : IO {}
main =
  let e = loop   [Eq String Int] {}     in
  let i = coerce [String]  [Int] e  "X" in

  putStr (showInt i)